# Copy the values you receive from eBay into your root .env file.
# This file is just a checklist/template for the local server.

EBAY_ENVIRONMENT=sandbox

# App credentials
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_RUNAME=

# Selling configuration
EBAY_MERCHANT_LOCATION_KEY=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=
EBAY_FULFILLMENT_POLICY_ID=

# Strongly recommended for sandbox
EBAY_CATEGORY_ID=

# Local server config
EBAY_SERVER_PORT=8787
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_CURRENCY=USD
EBAY_LOCALE=en-US

# App -> backend connection
# For local device testing, use your computer's LAN IP, not localhost.
# Example: http://192.168.1.42:8787
EXPO_PUBLIC_EBAY_API_BASE_URL=
